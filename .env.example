# LogStorm - локальные переменные окружения
# ВАЖНО: Не публикуйте реальные секреты в Git.
#
# Здесь можно задать общую collector DB для API, analyzer и миграций.
# Допускается локальный SQLite path или полный SQLAlchemy URL.
#
# Новый предпочтительный ключ:
# LOGSTORM_COLLECTOR_DB_URL=postgresql+psycopg://user:pass@localhost/logstorm
#
# Старый ключ совместимости тоже поддерживается:
# LOGSTORM_COLLECTOR_DB_PATH=/path/to/events.db
#
# Collector paths / runtime:
# LOGSTORM_COLLECTOR_NDJSON_PATH=/mnt/face_id/data/events.ndjson
# LOGSTORM_COLLECTOR_LOG_FILE=/mnt/face_id/logs/collector.log
# LOGSTORM_COLLECTOR_INTERVAL_MINUTES=15
# LOGSTORM_COLLECTOR_MAX_PARALLEL=4
# LOGSTORM_COLLECTOR_INITIAL_DAYS=60
# LOGSTORM_COLLECTOR_PAGE_SIZE=30
# LOGSTORM_COLLECTOR_TIMEOUT_SECONDS=180
# LOGSTORM_COLLECTOR_RETRIES=3
# LOGSTORM_COLLECTOR_EVENT_MAJOR=5
# LOGSTORM_COLLECTOR_EVENT_MINOR=75
#
# Collector images:
# LOGSTORM_COLLECTOR_IMAGES_ENABLED=true
# LOGSTORM_COLLECTOR_IMAGES_FOLDER=/mnt/face_id/data/images
# LOGSTORM_COLLECTOR_IMAGES_UNC_PATH=//172.11.1.254/Face_ID/data/images
# LOGSTORM_COLLECTOR_IMAGES_FORMAT={date}/{employeeNoString}_{time}_{serialNo}.jpg
#
# Collector devices. Recommended: one JSON array instead of many DEVICE_1/... vars.
# LOGSTORM_COLLECTOR_DEVICES_JSON=[{"name":"Камера входа","host":"192.168.1.101","user":"admin","password":"CHANGE_ME","enabled":true,"save_images":true}]
#
# Legacy indexed device vars still work:
# LOGSTORM_DEVICE_1_NAME=Камера входа
# LOGSTORM_DEVICE_1_HOST=192.168.1.101
# LOGSTORM_DEVICE_1_USER=admin
# LOGSTORM_DEVICE_1_PASSWORD=CHANGE_ME
# LOGSTORM_DEVICE_1_ENABLED=true
# LOGSTORM_DEVICE_1_SAVE_IMAGES=true

# Маппинг путей к фото событий, если collector записал Windows/UNC-путь,
# а API читает тот же ресурс через Linux mount.
# Формат: <путь_в_БД>=<локальный_путь>;...
# LOGSTORM_PHOTO_PATH_REWRITES=//172.11.1.254/Face_ID=/mnt/face_id
