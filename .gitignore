# Git ignore файл для LogStorm

# Секреты и конфигурация
.env
*.env
secrets.json
config.json
config.local.json
collector.local.py

# Результаты работы
attendance_report.xlsx
ai_summary.txt
*.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual Environment
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints

# Данные (не коммитить рабочие данные)
data/
logs/*.ndjson
logs/*.csv
logs/*.log
reports/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Сохраняем примеры
!data/.gitkeep
!logs/.gitkeep
!reports/.gitkeep

# Collector (конфиг с паролями)
collector/collector.json
collector/collector.local.py
collector/collector.log
collector/collector_state.json
collector/__pycache__/
